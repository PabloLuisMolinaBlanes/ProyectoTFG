generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model profile {
  hospital_id   Int    @id @default(autoincrement())
  hospital String @db.VarChar(100)
  password String @db.VarChar(100)
  test test[] 
}

model test {
    id String @id 
    hospital_id Int
    profile profile @relation(fields: [hospital_id], references: [hospital_id], onDelete: Cascade, map: "Hospital_FK")
    results_reaction_time String
    results_first_potentiometer String
    results_second_potentiometer String    
} 