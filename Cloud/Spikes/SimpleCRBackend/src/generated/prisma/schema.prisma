generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Profile {
  HospitalID Int    @id @default(autoincrement())
  hospital   String @db.VarChar(100)
  password   String @db.VarChar(100)
  Test       Test[]
}

model Test {
  id                           String  @id
  hospital_id                  Int
  Profile                      Profile @relation(fields: [hospital_id], references: [HospitalID], onDelete: Cascade, map: "Hospital_FK")
  results_reaction_time        String
  results_first_potentiometer  String
  results_second_potentiometer String
}
